# Generated by setup.sh — do not edit directly, edit config.env instead
# Baked into the Next.js image at build time (NEXT_PUBLIC_ vars are embedded by the compiler).
# Re-run setup.sh and rebuild the Docker image if this value changes.

NEXT_PUBLIC_LIVEKIT_URL=wss://${BASE_DOMAIN}/livekit

# Server-side only — used by Next.js middleware to validate subdomains against the backend.
# Points directly to the backend (not via nginx) so it works inside the Docker network.
