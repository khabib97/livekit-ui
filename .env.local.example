# ─────────────────────────────────────────────────────────────────────────────
# Local development — run `npm run dev` and connect to the production backend
#
# Setup:
#   cp .env.local.example .env.local
#   npm install
#   npm run dev          # http://localhost:3000
# ─────────────────────────────────────────────────────────────────────────────

# ── API proxy ─────────────────────────────────────────────────────────────────
# next.config.mjs rewrites /api/v1/* → BACKEND_ORIGIN/api/v1/*  (server-side, no CORS)
BACKEND_ORIGIN=https://gomeeting.video

# ── Middleware (server-side only) ─────────────────────────────────────────────
# The middleware validates subdomains by calling BACKEND_URL/api/v1/branding/{sub}
BACKEND_URL=https://gomeeting.video

# ── Subdomain detection ───────────────────────────────────────────────────────
# OPTION A — Disable subdomain routing entirely (simplest)
#   Leave NEXT_PUBLIC_BASE_DOMAIN blank.
#   Everything runs as the "main domain". Tenant pages still work but without
#   branding. To test a specific tenant, manually set a _tenant cookie in
#   DevTools → Application → Cookies → _tenant = your-subdomain
#
# OPTION B — Full subdomain testing with lvh.me (*.lvh.me resolves to 127.0.0.1)
#   Set NEXT_PUBLIC_BASE_DOMAIN=lvh.me
#   Then access http://yoursubdomain.lvh.me:3000 for tenant context.
#   Main domain: http://lvh.me:3000
NEXT_PUBLIC_BASE_DOMAIN=

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Use the production LiveKit server (WebSocket via Nginx on the main server)
NEXT_PUBLIC_LIVEKIT_URL=wss://gomeeting.video/livekit
